---
import type { Brand } from '../types.ts'
import { CATEGORY_LABELS, CATEGORIES } from '../types.ts'
import BrandCard from './BrandCard.astro'
import BrandModal from './BrandModal.astro'

interface Props { brands: Brand[] }
const { brands } = Astro.props
---

<section id="gallery" class="max-w-7xl mx-auto px-6 pb-16">
  <!-- Controls -->
  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 py-6 sticky top-12 z-30 bg-[#0a0a0a]/95 backdrop-blur-sm">

    <!-- Category tabs -->
    <div class="flex gap-1 flex-wrap">
      {CATEGORIES.map(cat => (
        <button
          class="tab-btn text-xs px-3.5 py-1.5 rounded-full border border-transparent text-[#888] transition-colors hover:text-[#ccc]"
          data-category={cat}
          data-active={cat === 'all' ? 'true' : 'false'}
        >
          {CATEGORY_LABELS[cat]}{cat === 'all' ? ` (${brands.length})` : ''}
        </button>
      ))}
    </div>

    <!-- Search + count -->
    <div class="flex items-center gap-3 self-stretch sm:self-auto">
      <div class="flex items-center gap-2 bg-[#1a1a1a] border border-[#2a2a2a] rounded-lg px-3 py-1.5 text-[11px] text-[#555] min-w-[180px]">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          id="gallery-search"
          type="search"
          placeholder="搜索品牌..."
          class="bg-transparent outline-none w-full text-[#aaa] placeholder:text-[#555]"
        />
      </div>
      <span id="gallery-count" class="text-[11px] text-[#555] whitespace-nowrap">
        {brands.length} styles
      </span>
    </div>
  </div>

  <!-- Card grid -->
  <div
    id="gallery-grid"
    class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-3"
  >
    {brands.map(brand => (
      <BrandCard brand={brand} />
    ))}
  </div>

  <!-- Empty state -->
  <div id="gallery-empty" class="hidden text-center py-20 text-[#555] text-sm">
    没有找到匹配的品牌
  </div>

  <BrandModal />
</section>

<script define:vars={{ brands }}>
// ── Gallery filter + search ───────────────────────────────────────────────────

const searchInput = document.getElementById('gallery-search')
const countEl = document.getElementById('gallery-count')
const emptyEl = document.getElementById('gallery-empty')
const tabBtns = document.querySelectorAll('.tab-btn')
const cards = document.querySelectorAll('.brand-card')

let activeCategory = 'all'
let searchQuery = ''

function updateActiveTab() {
  tabBtns.forEach(btn => {
    const isActive = btn.dataset.category === activeCategory
    btn.dataset.active = String(isActive)
    if (isActive) {
      btn.style.background = '#10b98119'
      btn.style.borderColor = '#10b98133'
      btn.style.color = '#10b981'
    } else {
      btn.style.background = ''
      btn.style.borderColor = 'transparent'
      btn.style.color = ''
    }
  })
}

function updateGallery() {
  let visible = 0
  cards.forEach(card => {
    const id = card.dataset.brandId
    const name = (card.dataset.brandName || '').toLowerCase()
    const category = card.dataset.brandCategory

    const brand = brands.find(b => b.id === id)
    const tagline = (brand?.tagline || '').toLowerCase()

    const matchCategory = activeCategory === 'all' || category === activeCategory
    const matchSearch = !searchQuery
      || name.includes(searchQuery)
      || tagline.includes(searchQuery)

    const show = matchCategory && matchSearch
    card.hidden = !show
    if (show) visible++
  })

  countEl.textContent = `${visible} style${visible !== 1 ? 's' : ''}`
  emptyEl.classList.toggle('hidden', visible > 0)
}

tabBtns.forEach(btn => {
  btn.addEventListener('click', () => {
    activeCategory = btn.dataset.category
    updateActiveTab()
    updateGallery()
  })
})

searchInput?.addEventListener('input', e => {
  searchQuery = e.target.value.trim().toLowerCase()
  updateGallery()
})

// Initialize active tab styling
updateActiveTab()

// ── Modal open/close ──────────────────────────────────────────────────────────

const modal = document.getElementById('brand-modal')
const modalClose = document.getElementById('modal-close')

function showToast(message, isError = false) {
  const toast = document.getElementById('toast')
  toast.textContent = message
  toast.style.background = isError ? '#ef4444' : '#10b981'
  toast.style.color = isError ? '#fff' : '#000'
  toast.style.opacity = '1'
  setTimeout(() => { toast.style.opacity = '0' }, 2500)
}

function openModal(brand) {
  // Icon
  const icon = document.getElementById('modal-icon')
  icon.textContent = brand.name[0]
  icon.style.background = brand.tokens.colors[0]?.hex ?? '#888'

  // Header
  document.getElementById('modal-name').textContent = brand.name
  document.getElementById('modal-tagline').textContent = brand.tagline
  document.getElementById('modal-category').textContent = brand.category

  // Screenshot
  const screenshot = document.getElementById('modal-screenshot')
  screenshot.src = `/screenshots/${brand.id}.webp`
  screenshot.alt = `${brand.name} website`
  let hostname = brand.websiteUrl
  try { hostname = new URL(brand.websiteUrl).hostname } catch {}
  document.getElementById('modal-caption').textContent = `${hostname} · Updated monthly`

  // Colors
  const colorsEl = document.getElementById('modal-colors')
  colorsEl.innerHTML = ''
  brand.tokens.colors.forEach(c => {
    const wrapper = document.createElement('div')
    wrapper.style.cssText = 'display:flex;flex-direction:column;align-items:center;gap:4px'
    const swatch = document.createElement('div')
    swatch.style.cssText = `width:28px;height:28px;border-radius:7px;border:1px solid #ffffff0d`
    swatch.style.background = c.hex
    const label = document.createElement('span')
    label.style.cssText = 'font-size:8px;color:#555;font-family:monospace'
    label.textContent = c.hex
    wrapper.appendChild(swatch)
    wrapper.appendChild(label)
    colorsEl.appendChild(wrapper)
  })

  // Typography
  const typoEl = document.getElementById('modal-typography')
  typoEl.innerHTML = ''
  const fontFam = brand.tokens.fontFamily
  const brandNameUpper = brand.name.toUpperCase()
  const fontShort = fontFam.split(',')[0]

  const rows = [
    { label: 'H1', text: brandNameUpper, style: `font-size:14px;font-weight:800;letter-spacing:0.05em;text-transform:uppercase`, meta: fontShort },
    { label: 'Body', text: 'The quick brown fox jumps', style: 'font-size:11px;color:#aaa', meta: null },
    { label: 'Label', text: 'CONFIGURE', style: 'font-size:9px;color:#666;letter-spacing:0.08em;text-transform:uppercase', meta: null },
  ]
  rows.forEach(({ label, text, style, meta }) => {
    const row = document.createElement('div')
    row.style.cssText = 'display:flex;align-items:baseline;gap:8px'
    const lbl = document.createElement('span')
    lbl.style.cssText = 'font-size:8px;color:#555;width:28px;flex-shrink:0'
    lbl.textContent = label
    const sample = document.createElement('span')
    sample.style.cssText = style
    sample.style.fontFamily = fontFam
    sample.textContent = text
    row.appendChild(lbl)
    row.appendChild(sample)
    if (meta) {
      const metaEl = document.createElement('span')
      metaEl.style.cssText = 'font-size:9px;color:#444;margin-left:auto'
      metaEl.textContent = meta
      row.appendChild(metaEl)
    }
    typoEl.appendChild(row)
  })

  // Buttons
  const radiusMap = { 'rounded-none': '0', 'rounded-sm': '4px', 'rounded-md': '8px', 'rounded-full': '9999px' }
  const radius = radiusMap[brand.tokens.borderRadius] ?? '8px'
  const accent = brand.tokens.colors[0]?.hex ?? '#10b981'
  const buttonsEl = document.getElementById('modal-buttons')
  buttonsEl.innerHTML = ''
  const primaryBtn = document.createElement('button')
  primaryBtn.style.cssText = `border:none;padding:5px 14px;font-size:10px;font-weight:700;letter-spacing:0.05em;text-transform:uppercase`
  primaryBtn.style.background = accent
  primaryBtn.style.color = isLight(accent) ? '#000' : '#fff'
  primaryBtn.style.borderRadius = radius
  primaryBtn.textContent = 'PRIMARY'
  const ghostBtn = document.createElement('button')
  ghostBtn.style.cssText = `background:transparent;color:#ccc;border:1px solid #333;padding:5px 14px;font-size:10px;letter-spacing:0.05em;text-transform:uppercase`
  ghostBtn.style.borderRadius = radius
  ghostBtn.textContent = 'GHOST'
  buttonsEl.appendChild(primaryBtn)
  buttonsEl.appendChild(ghostBtn)
  document.getElementById('modal-button-style').textContent = brand.tokens.buttonStyle

  // Footer
  document.getElementById('modal-meta').textContent = `${brand.id}/DESIGN.md`
  document.getElementById('modal-preview-link').href = brand.previewUrl

  // Copy button - reset to default state
  const copyBtn = document.getElementById('modal-copy-btn')
  copyBtn.textContent = ''
  const svgNS = 'http://www.w3.org/2000/svg'
  const svg = document.createElementNS(svgNS, 'svg')
  svg.setAttribute('width', '12')
  svg.setAttribute('height', '12')
  svg.setAttribute('viewBox', '0 0 24 24')
  svg.setAttribute('fill', 'none')
  svg.setAttribute('stroke', 'currentColor')
  svg.setAttribute('stroke-width', '2.5')
  const path = document.createElementNS(svgNS, 'path')
  path.setAttribute('d', 'M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4')
  const poly = document.createElementNS(svgNS, 'polyline')
  poly.setAttribute('points', '7 10 12 15 17 10')
  const line = document.createElementNS(svgNS, 'line')
  line.setAttribute('x1', '12'); line.setAttribute('y1', '15')
  line.setAttribute('x2', '12'); line.setAttribute('y2', '3')
  svg.appendChild(path); svg.appendChild(poly); svg.appendChild(line)
  copyBtn.appendChild(svg)
  const btnLabel = document.createElement('span')
  btnLabel.textContent = ' 复制 DESIGN.md'
  copyBtn.appendChild(btnLabel)
  copyBtn.style.background = '#10b981'
  copyBtn.style.color = '#000'
  copyBtn.onclick = () => handleCopy(brand)

  // Mark active card
  document.querySelectorAll('.brand-card').forEach(c => {
    c.style.outline = ''
    c.style.boxShadow = ''
  })
  const activeCard = document.querySelector(`.brand-card[data-brand-id="${brand.id}"]`)
  if (activeCard) {
    activeCard.style.outline = '1px solid #10b981'
    activeCard.style.boxShadow = '0 0 12px #10b98133'
  }

  modal.showModal()
}

function handleCopy(brand) {
  fetch(brand.rawMdUrl)
    .then(r => {
      if (!r.ok) throw new Error(`HTTP ${r.status}`)
      return r.text()
    })
    .then(text => navigator.clipboard.writeText(text))
    .then(() => showToast('已复制! ✓'))
    .catch(() => {
      showToast('复制失败，请手动访问链接', true)
      const btn = document.getElementById('modal-copy-btn')
      btn.textContent = '在新标签页打开 →'
      btn.style.background = '#1a1a1a'
      btn.style.color = '#aaa'
      btn.onclick = () => window.open(brand.rawMdUrl, '_blank')
    })
}

function isLight(hex) {
  const r = parseInt(hex.slice(1,3),16)
  const g = parseInt(hex.slice(3,5),16)
  const b = parseInt(hex.slice(5,7),16)
  return (r*299 + g*587 + b*114) / 1000 > 128
}

// Open modal on card click
document.getElementById('gallery-grid').addEventListener('click', e => {
  const card = e.target.closest('.brand-card')
  if (!card) return
  const brand = brands.find(b => b.id === card.dataset.brandId)
  if (brand) openModal(brand)
})

// Close modal
modalClose?.addEventListener('click', () => modal.close())
modal.addEventListener('click', e => { if (e.target === modal) modal.close() })
modal.addEventListener('close', () => {
  document.querySelectorAll('.brand-card').forEach(c => {
    c.style.outline = ''
    c.style.boxShadow = ''
  })
})
</script>
