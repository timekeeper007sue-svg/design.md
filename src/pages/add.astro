---
import Nav from '../components/Nav.astro'
import { brandCount } from '../data/brands.ts'
---

<!doctype html>
<html lang="zh" class="bg-[#0a0a0a] text-[#e0e0e0]">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add a Style — Awesome DESIGN.md</title>
    <meta name="description" content="输入任意网站 URL，自动提取设计 token 并生成 DESIGN.md。" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen font-sans antialiased">
    <Nav count={brandCount} />

    <main class="relative">
      <!-- Green glow -->
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px]
                  bg-[radial-gradient(ellipse_at_top,#10b98119,transparent_70%)]
                  pointer-events-none"></div>

      <!-- Hero -->
      <section class="relative pt-20 pb-10 px-6 text-center overflow-hidden">
        <div class="relative max-w-2xl mx-auto">
          <div class="inline-block bg-[#10b98114] border border-[#10b98133]
                      rounded-full px-3 py-1 text-xs text-[#10b981] mb-5 tracking-wide">
            Extract & Generate
          </div>

          <h1 class="text-4xl sm:text-5xl font-bold text-white tracking-tight leading-tight mb-4">
            Add a <span class="text-[#10b981]">Style</span>
          </h1>
          <p class="text-base text-[#666] max-w-md mx-auto leading-relaxed">
            输入任意网站 URL，自动提取颜色、字体、间距等设计 token，生成标准 DESIGN.md 文件。
          </p>
        </div>
      </section>

      <!-- Input section -->
      <section class="px-6 pb-16">
        <div class="max-w-2xl mx-auto">
          <!-- URL input card -->
          <div class="border border-[#1e1e1e] rounded-[10px] bg-[#111] p-5">
            <label for="url-input" class="text-xs text-[#777] mb-2 block">Website URL</label>
            <div class="flex gap-3">
              <input
                id="url-input"
                type="url"
                placeholder="https://linear.app"
                class="flex-1 bg-[#0a0a0a] border border-[#2a2a2a] rounded-lg px-4 py-2.5 text-sm text-[#e0e0e0]
                       placeholder:text-[#444] outline-none focus:border-[#10b98155] transition-colors"
              />
              <button
                id="extract-btn"
                class="bg-[#10b981] text-black font-semibold text-sm px-5 py-2.5 rounded-lg
                       hover:bg-[#0ea572] transition-colors flex items-center gap-2 whitespace-nowrap
                       disabled:opacity-50 disabled:cursor-not-allowed"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
                  <path d="M21 3v6h-6"/>
                </svg>
                Extract
              </button>
            </div>
            <p id="url-error" class="text-xs text-[#ef4444] mt-2 hidden"></p>
          </div>

          <!-- Progress -->
          <div id="progress-section" class="hidden mt-4 border border-[#1e1e1e] rounded-[10px] bg-[#111] p-5">
            <div class="flex items-center gap-3">
              <div class="w-4 h-4 border-2 border-[#10b98133] border-t-[#10b981] rounded-full animate-spin"></div>
              <span id="progress-text" class="text-sm text-[#888]">正在提取设计 token...</span>
            </div>
          </div>

          <!-- Result -->
          <div id="result-section" class="hidden mt-4 space-y-4">
            <div class="border border-[#1e1e1e] rounded-[10px] bg-[#111] p-5">
              <div class="flex items-center justify-between mb-4">
                <h2 class="text-sm font-semibold text-[#e0e0e0]">Extracted Tokens</h2>
                <span id="result-domain" class="text-xs text-[#555] bg-[#1a1a1a] px-2 py-px rounded"></span>
              </div>
              <div id="token-preview" class="space-y-4"></div>
            </div>

            <div class="border border-[#1e1e1e] rounded-[10px] bg-[#111] p-5">
              <div class="flex items-center justify-between mb-4">
                <h2 class="text-sm font-semibold text-[#e0e0e0]">Generated DESIGN.md</h2>
                <button id="copy-md-btn" class="text-xs text-[#10b981] hover:text-[#0ea572] transition-colors flex items-center gap-1">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                  </svg>
                  Copy
                </button>
              </div>
              <pre id="md-preview" class="bg-[#0a0a0a] border border-[#1a1a1a] rounded-lg p-4 text-xs text-[#888] leading-relaxed overflow-auto max-h-[400px] font-mono"></pre>
            </div>

            <div class="flex gap-3">
              <a id="download-btn"
                 class="flex-1 text-center bg-[#10b981] text-black font-semibold text-sm px-5 py-2.5 rounded-lg
                        hover:bg-[#0ea572] transition-colors">
                Download DESIGN.md
              </a>
            </div>
          </div>

          <!-- Error -->
          <div id="error-section" class="hidden mt-4 border border-[#ef444433] rounded-[10px] bg-[#111] p-5">
            <div class="flex items-center gap-2 mb-2">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2">
                <circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/>
              </svg>
              <h2 class="text-sm font-semibold text-[#ef4444]">Extraction Failed</h2>
            </div>
            <p id="error-text" class="text-xs text-[#777] leading-relaxed"></p>
            <button id="retry-btn" class="mt-3 text-xs text-[#10b981] hover:underline">Retry</button>
          </div>
        </div>
      </section>
    </main>

    <footer class="border-t border-[#1a1a1a] py-8 px-6">
      <div class="max-w-7xl mx-auto text-center">
        <span class="text-xs text-[#444]">Awesome DESIGN.md · MIT License</span>
      </div>
    </footer>

    <script>
    const urlInput = document.getElementById('url-input') as HTMLInputElement
    const extractBtn = document.getElementById('extract-btn') as HTMLButtonElement
    const urlError = document.getElementById('url-error')!
    const progressSection = document.getElementById('progress-section')!
    const progressText = document.getElementById('progress-text')!
    const resultSection = document.getElementById('result-section')!
    const errorSection = document.getElementById('error-section')!
    const errorText = document.getElementById('error-text')!

    let currentMd = ''

    function showUrlError(msg: string) {
      urlError.textContent = msg
      urlError.classList.remove('hidden')
    }

    function showProgress(msg: string) {
      urlError.classList.add('hidden')
      progressSection.classList.remove('hidden')
      resultSection.classList.add('hidden')
      errorSection.classList.add('hidden')
      progressText.textContent = msg
    }

    function showResult() {
      progressSection.classList.add('hidden')
      resultSection.classList.remove('hidden')
      errorSection.classList.add('hidden')
    }

    function showError(msg: string) {
      progressSection.classList.add('hidden')
      resultSection.classList.add('hidden')
      errorSection.classList.remove('hidden')
      errorText.textContent = msg
    }

    extractBtn.addEventListener('click', async () => {
      urlError.classList.add('hidden')
      const url = urlInput.value.trim()

      if (!url) { showUrlError('请输入网站 URL'); return }
      try { new URL(url) } catch { showUrlError('URL 格式不正确，请输入完整地址（如 https://linear.app）'); return }

      extractBtn.disabled = true
      showProgress('正在提取设计 token...')

      try {
        const res = await fetch('/api/extract', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ url }),
        })

        const data = await res.json()

        if (!res.ok) {
          showError(data.error || 'Unknown error')
          extractBtn.disabled = false
          return
        }

        currentMd = data.markdown
        const tokens = data.tokens

        // Domain badge
        document.getElementById('result-domain')!.textContent = data.domain

        // Token preview
        const colorsHtml = tokens.colors.slice(0, 8).map((c: any) =>
          `<div class="flex flex-col items-center gap-1">
            <span class="w-6 h-6 rounded border border-white/5" style="background:${c.hex}"></span>
            <span class="text-[9px] text-[#555] font-mono">${c.hex}</span>
          </div>`
        ).join('')

        const fontLine = tokens.fontFamily.length
          ? `<div class="text-xs text-[#888]">${tokens.fontFamily.join(', ')}</div>`
          : ''

        const sizeLine = tokens.fontSize.length
          ? `<div class="text-xs text-[#888]">${tokens.fontSize.slice(0, 3).map((s: any) => s.value).join(' · ')}</div>`
          : ''

        document.getElementById('token-preview')!.innerHTML = `
          <div>
            <div class="text-[10px] text-[#555] mb-2">Colors (${tokens.colors.length})</div>
            <div class="flex flex-wrap gap-2">${colorsHtml}</div>
          </div>
          ${fontLine ? `<div><div class="text-[10px] text-[#555] mb-1">Typography</div>${fontLine}${sizeLine}</div>` : ''}
        `

        // MD preview
        document.getElementById('md-preview')!.textContent = currentMd

        // Download
        const downloadBtn = document.getElementById('download-btn')!
        downloadBtn.setAttribute('href', 'data:text/markdown;charset=utf-8,' + encodeURIComponent(currentMd))
        downloadBtn.setAttribute('download', `DESIGN-${data.domain}.md`)

        showResult()
      } catch (err: any) {
        showError(err.message || 'Network error')
      } finally {
        extractBtn.disabled = false
      }
    })

    urlInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') extractBtn.click() })
    document.getElementById('retry-btn')!.addEventListener('click', () => extractBtn.click())

    document.getElementById('copy-md-btn')!.addEventListener('click', () => {
      navigator.clipboard.writeText(currentMd).then(() => {
        const btn = document.getElementById('copy-md-btn')!
        const orig = btn.innerHTML
        btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg> Copied!'
        setTimeout(() => { btn.innerHTML = orig }, 2000)
      })
    })
    </script>
  </body>
</html>
